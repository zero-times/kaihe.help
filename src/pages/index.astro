---
import { getCollection, getEntry, render } from "astro:content";
import BaseLayout from "@/layouts/BaseLayout.astro";
import StepList from "@/components/StepList.astro";

const homeEntry = await getEntry("pages", "index");

if (!homeEntry) {
  throw new Error("Missing home page content entry.");
}

const { Content } = await render(homeEntry);
const allEntries = await getCollection("pages", ({ id }) => id !== "index");

const order = [
  "what-to-do-after-doxxing",
  "phone-number-exposed",
  "family-info-exposed",
  "report-or-police-first",
  "how-to-report-12377",
  "first-30-minutes-checklist",
  "evidence-checklist",
  "family-message-template",
];

const orderedEntries = order
  .map((slug) => allEntries.find((entry) => entry.id === slug))
  .filter((entry): entry is (typeof allEntries)[number] => Boolean(entry));

const quickSteps = [
  {
    label: "先留证",
    title: "把页面、账号、时间先固定下来",
    text: "截图前后文、复制链接、录一段滚动视频，先保留原始状态，不要只截单张图。",
    href: "/evidence-checklist",
    actionText: "看留证清单",
  },
  {
    label: "先控扩散",
    title: "先处理还没继续外溢的入口",
    text: "优先改隐私设置、关闭公开入口、提醒家人朋友暂时别回应陌生联系。",
    href: "/what-to-do-after-doxxing",
    actionText: "看控扩散建议",
  },
  {
    label: "先分流",
    title: "判断该举报、申诉还是尽快报警",
    text: "没有明显线下风险时先平台处理；出现威胁、住址、学校或家人信息时别拖。",
    href: "/report-or-police-first",
    actionText: "看举报 / 报警判断",
  },
  {
    label: "先通知",
    title: "只提醒必要的人，不要大范围转述",
    text: "把风险和统一话术发给家人或朋友，避免他们因慌乱而主动暴露更多信息。",
    href: "/family-message-template",
    actionText: "看家人提醒模板",
  },
];

const scenarioCards = [
  {
    title: "我已经被开盒了",
    text: "已经看到信息被公开，先按总流程止损。",
    href: "/what-to-do-after-doxxing",
    actionText: "看这一页",
  },
  {
    title: "我怀疑手机号或隐私被挂了",
    text: "先判断扩散范围，再处理高风险入口。",
    href: "/phone-number-exposed",
    actionText: "看这一页",
  },
  {
    title: "我是在帮家人或朋友处理",
    text: "先通知、先分工、先统一回复。",
    href: "/family-info-exposed",
    actionText: "看这一页",
  },
];

const heroLead =
  "先留证，先控扩散，再判断举报还是报警。已经出现威胁、住址、家人或未成年人信息时，不要拖。";

const homeSchema = [
  {
    "@context": "https://schema.org",
    "@type": "WebPage",
    name: homeEntry.data.title,
    description: homeEntry.data.description,
    url: "https://kaihe.help/",
    inLanguage: "zh-CN",
  },
];
---

<BaseLayout title={homeEntry.data.title} description={homeEntry.data.description} jsonLd={homeSchema}>
  <section class="hero">
    <div class="hero-grid">
      <div class="hero-copy">
        <p class="hero-tag">第一小时先做什么</p>
        <h1 class="hero-title">{homeEntry.data.title}</h1>
        <p class="hero-lede">{heroLead}</p>
        <div class="hero-actions">
          <a class="primary-button" href="/first-30-minutes-checklist">先看 30 分钟处理清单</a>
          <a class="secondary-button" href="/what-to-do-after-doxxing">进入总流程</a>
        </div>
        <aside class="hero-alert" aria-labelledby="hero-alert-title">
          <p class="hero-alert-tag">高风险提醒</p>
          <p id="hero-alert-title" class="hero-alert-text">
            如果已经出现人身威胁、线下接触、敲诈、未成年人信息泄露或家人联系方式扩散，请先留证，再尽快报警。
          </p>
        </aside>
      </div>

      <div class="hero-panel">
        <div class="manual-card">
          <p class="manual-tag">首屏先看</p>
          <h2>先做这 4 步</h2>
          <StepList items={quickSteps} />
        </div>
      </div>
    </div>
  </section>

  <section class="content-section">
    <div class="section-heading-group">
      <p class="section-tag">先按你的情况进入</p>
      <h2 class="section-heading">不用一次看完整站</h2>
      <p class="section-lede">先选最接近你的情况，再一步一步处理。</p>
    </div>

    <div class="scenario-grid">
      {
        scenarioCards.map((item) => (
          <article class="scenario-card">
            <strong>{item.title}</strong>
            <p>{item.text}</p>
            <a class="scenario-link" href={item.href}>{item.actionText}</a>
          </article>
        ))
      }
    </div>
  </section>

  <section class="content-section editorial-block">
    <div class="section-heading-group">
      <p class="section-tag">先把顺序排好</p>
      <h2 class="section-heading">你现在最需要的，不是更多解释</h2>
      <p class="section-lede">而是先把前 30 分钟该做的事排清楚。</p>
    </div>
    <div class="editorial-prose prose">
      <Content />
    </div>
  </section>

  <section class="content-section">
    <div class="section-heading-group">
      <p class="section-tag">常见问题</p>
      <h2 class="section-heading">这些问题最常被单独搜到</h2>
      <p class="section-lede">按你遇到的情况进入，不用从头读完整站。</p>
    </div>

    <div class="page-grid">
      {
        orderedEntries.map((entry) => (
          <a class="page-card" href={`/${entry.id}`}>
            <span class="page-card-tag">常见问题</span>
            <strong>{entry.data.title}</strong>
            <p>{entry.data.description}</p>
            <span class="page-card-link">看这一页</span>
          </a>
        ))
      }
    </div>
  </section>
</BaseLayout>
